{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)",
      "Read(**/*.reg)",
      "Edit(**/*.reg)",
      "Write(**/*.reg)",
      "Read(//**/*.reg)",
      "Edit(//**/*.reg)",
      "Write(//**/*.reg)",
      "Edit(**/*.bat)",
      "Write(**/*.bat)",
      "Edit(//**/*.bat)",
      "Write(//**/*.bat)",
      "Edit(**/*.cmd)",
      "Write(**/*.cmd)",
      "Edit(//**/*.cmd)",
      "Write(//**/*.cmd)"
    ],
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com/anthropics)"
    ]
  },
  "enabledMcpjsonServers": [
    "anthropic-docs",
    "context7",
    "fetch",
    "github"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status --short"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "if": "Read(**/*.bat)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/bat_cp932_guard.py", "pre"]
          },
          {
            "type": "command",
            "if": "Read(//**/*.bat)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/bat_cp932_guard.py", "pre"]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Read(.claude/.bat-shadow/**)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/bat_cp932_guard.py", "post"]
          },
          {
            "type": "command",
            "if": "Edit(.claude/.bat-shadow/**)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/bat_cp932_guard.py", "post"]
          },
          {
            "type": "command",
            "if": "Write(.claude/.bat-shadow/**)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/bat_cp932_guard.py", "post"]
          },
          {
            "type": "command",
            "if": "Edit(**/*.ps1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Write(**/*.ps1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Edit(**/*.psm1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Write(**/*.psm1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Edit(**/*.psd1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Write(**/*.psd1)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Edit(**/*.ps1.template)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          },
          {
            "type": "command",
            "if": "Write(**/*.ps1.template)",
            "command": "python",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/ps1_bom_crlf_check.py"]
          }
        ]
      }
    ]
  }
}
